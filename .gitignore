# ==========================================
# KIPU CORE - ESTRUCTURA DE COMPILACIÓN
# ==========================================
target/
bin/
build/
src/main/java/com/kipu/core/identity/application/port/out/
.mvn/wrapper/maven-wrapper.jar
# Mantener carpetas de target si son necesarias para tests específicos (opcional)
!**/src/main/**/target/
!**/src/test/**/target/

# ==========================================
# CONFIGURACIÓN DE IDE (IntelliJ, VSCode, STS)
# ==========================================
.idea/
*.iws
*.iml
*.ipr
.vscode/
.settings/
.classpath
.project
.factorypath
.apt_generated
.springBeans
.sts4-cache
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# ==========================================
# INFRAESTRUCTURA Y DATOS LOCALES
# ==========================================
# Ignorar logs de la aplicación
*.log
logs/
tmp/

# Ignorar datos persistentes de Docker (si mapeas volúmenes)
db-data/
postgres-data/

# Archivos de entorno y secretos (¡CRÍTICO!)
.env
*.jks
*.p12
*.key
/src/main/resources/*.jks

# ==========================================
# SISTEMA OPERATIVO
# ==========================================
.DS_Store
Thumbs.db
desktop.ini

